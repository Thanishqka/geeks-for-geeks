class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int a=nums.length;
        int max=0;
        int count=0;
        for(int i=0;i<a;i++){
            if(nums[i]==1){
                count++;
                if(count>max){
                max=count;
            }
            }
            else{
                count=0;
            }
        }
        return max;
    }
}
